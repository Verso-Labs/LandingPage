---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Pricing — Verso AI" description="Choose the perfect plan for your presentation needs. Flexible credit-based pricing for everyone.">
  <Nav activePage="Pricing" />

  <!-- Pricing Section -->
  <section class="min-h-screen pt-[100px] px-[30px] pb-[60px] nav:py-20 nav:px-[60px]">
    <div class="text-center mb-[60px]">
      <h1 class="font-display text-[42px] nav:text-[64px] font-normal leading-tight text-brand mb-6">Pricing</h1>
      <p class="font-display text-[18px] nav:text-[20px] leading-relaxed text-brand-dark max-w-[600px] mx-auto">Start with 500 free credits. Pay for what you use on top.<br />Upgrade for plans to get the best deal.</p>
    </div>

    <!-- Billing Toggle -->
    <div class="flex justify-center mb-[60px]">
      <div class="relative inline-flex bg-white border-2 border-brand-border rounded-pill p-1 gap-1">
        <div id="toggleIndicator" class="absolute inset-y-1 bg-brand rounded-pill transition-all duration-200 pointer-events-none"></div>
        <button class="relative z-10 py-3 px-8 border-none bg-transparent text-white text-sm font-semibold cursor-pointer rounded-pill transition-colors duration-300 font-body" id="annualBtn">Annual (Save 25%)</button>
        <button class="relative z-10 py-3 px-8 border-none bg-transparent text-brand-muted text-sm font-semibold cursor-pointer rounded-pill transition-colors duration-300 font-body" id="monthlyBtn">Monthly</button>
      </div>
    </div>

    <!-- Pricing Cards -->
    <div class="max-w-[1200px] mx-auto grid grid-cols-1 nav:grid-cols-[repeat(auto-fit,minmax(320px,1fr))] gap-8">

      <!-- Starter Plan -->
      <div class="bg-white rounded-2xl p-10 border-2 border-brand-border transition duration-300 flex flex-col hover:-translate-y-2 hover:shadow-xl hover:border-brand">
        <div class="mb-6">
          <div class="flex items-center gap-3 mb-2">
            <h3 class="font-display text-[32px] font-semibold text-brand">Starter</h3>
            <img src="/hawk.svg" alt="Starter" class="w-[50px] h-[50px]" />
          </div>
          <p class="text-sm text-brand-muted leading-normal">Perfect for individuals that want to try out the solution</p>
        </div>

        <div class="mb-6 min-h-[80px]">
          <div class="flex items-baseline gap-2">
            <span class="text-[48px] font-bold text-brand font-display">$0</span>
            <span class="text-base text-brand-muted">/month</span>
          </div>
        </div>

        <div class="bg-brand-bg rounded-xl p-4 mb-6">
          <p class="text-sm leading-relaxed text-brand-dark"><span class="font-semibold text-brand">500 free credits</span> to get started</p>
          <p class="text-sm leading-relaxed text-brand-dark"><span class="font-semibold text-brand">$3</span> for 100 credits afterwards</p>
        </div>

        <ul class="list-none mb-8 flex-grow">
          <li class="flex items-start gap-3 mb-3 text-sm leading-relaxed text-brand-dark"><span class="text-brand font-bold text-base shrink-0">✓</span>AI-powered slide editing</li>
          <li class="flex items-start gap-3 mb-3 text-sm leading-relaxed text-brand-dark"><span class="text-brand font-bold text-base shrink-0">✓</span>Chat interface</li>
          <li class="flex items-start gap-3 mb-3 text-sm leading-relaxed text-brand-dark"><span class="text-brand font-bold text-base shrink-0">✓</span>PowerPoint add-in</li>
          <li class="flex items-start gap-3 mb-3 text-sm leading-relaxed text-brand-dark"><span class="text-brand font-bold text-base shrink-0">✓</span>Multi-format exports</li>
        </ul>

        <a href="https://verso.fly.dev/playground/" class="block w-full py-4 rounded-pill text-center no-underline text-sm font-semibold transition duration-300 cursor-pointer border-2 border-brand bg-transparent text-brand hover:bg-brand hover:text-white">Get Started</a>
      </div>

      <!-- Pro Plan -->
      <div class="bg-white rounded-2xl p-10 border-2 border-brand transition duration-300 flex flex-col relative hover:-translate-y-2 hover:shadow-xl">
        <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-brand text-white py-1.5 px-5 rounded-[20px] text-[11px] font-bold tracking-[1px] uppercase">Most Popular</span>
        <div class="mb-6">
          <div class="flex items-center gap-3 mb-2">
            <h3 class="font-display text-[32px] font-semibold text-brand">Pro</h3>
            <img src="/eagle.svg" alt="Pro" class="w-[50px] h-[50px]" />
          </div>
          <p class="text-sm text-brand-muted leading-normal">For professionals that need speed and efficiency</p>
        </div>

        <div class="mb-6 min-h-[80px]">
          <div class="flex items-baseline gap-2 annual-price">
            <span class="text-[36px] font-bold text-brand-light line-through font-display">$9</span>
            <span class="text-[48px] font-bold text-brand font-display">$7</span>
            <span class="text-base text-brand-muted">/month</span>
          </div>
          <div class="items-baseline gap-2 monthly-price hidden">
            <span class="text-[48px] font-bold text-brand font-display">$9</span>
            <span class="text-base text-brand-muted">/month</span>
          </div>
        </div>

        <div class="bg-brand-bg rounded-xl p-4 mb-6">
          <p class="text-sm leading-relaxed text-brand-dark"><span class="font-semibold text-brand">1,000 credits</span> per month</p>
          <p class="text-sm leading-relaxed text-brand-dark"><span class="font-semibold text-brand">$2</span> for 100 credits afterwards</p>
        </div>

        <ul class="list-none mb-8 flex-grow">
          <li class="flex items-start gap-3 mb-3 text-sm leading-relaxed text-brand-dark"><span class="text-brand font-bold text-base shrink-0">✓</span><strong>Everything in Starter</strong></li>
          <li class="flex items-start gap-3 mb-3 text-sm leading-relaxed text-brand-dark"><span class="text-brand font-bold text-base shrink-0">✓</span>Orizuru 2.1 harness</li>
          <li class="flex items-start gap-3 mb-3 text-sm leading-relaxed text-brand-dark"><span class="text-brand font-bold text-base shrink-0">✓</span>Custom templates</li>
          <li class="flex items-start gap-3 mb-3 text-sm leading-relaxed text-brand-dark"><span class="text-brand font-bold text-base shrink-0">✓</span>Team collaboration</li>
          <li class="flex items-start gap-3 mb-3 text-sm leading-relaxed text-brand-dark"><span class="text-brand font-bold text-base shrink-0">✓</span>Priority support</li>
        </ul>

        <a href="https://verso.fly.dev/playground/" class="block w-full py-4 rounded-pill text-center no-underline text-sm font-semibold transition duration-300 cursor-pointer border-2 border-brand bg-brand text-white hover:bg-black hover:-translate-y-0.5 hover:shadow-lg">Get Started</a>
      </div>

      <!-- Ultimate Plan -->
      <div class="bg-white rounded-2xl p-10 border-2 border-brand-border transition duration-300 flex flex-col hover:-translate-y-2 hover:shadow-xl hover:border-brand">
        <div class="mb-6">
          <div class="flex items-center gap-3 mb-2">
            <h3 class="font-display text-[32px] font-semibold text-brand">Ultimate</h3>
            <img src="/raptor.svg" alt="Ultimate" class="w-[50px] h-[50px]" />
          </div>
          <p class="text-sm text-brand-muted leading-normal">For growing teams and enterprises that need peak performance</p>
        </div>

        <div class="mb-6 min-h-[80px]">
          <div class="flex items-baseline gap-2 annual-price">
            <span class="text-[36px] font-bold text-brand-light line-through font-display">$49</span>
            <span class="text-[48px] font-bold text-brand font-display">$37</span>
            <span class="text-base text-brand-muted">/month</span>
          </div>
          <div class="items-baseline gap-2 monthly-price hidden">
            <span class="text-[48px] font-bold text-brand font-display">$49</span>
            <span class="text-base text-brand-muted">/month</span>
          </div>
        </div>

        <div class="bg-brand-bg rounded-xl p-4 mb-6">
          <p class="text-sm leading-relaxed text-brand-dark"><span class="font-semibold text-brand">5,000 credits</span> per month</p>
          <p class="text-sm leading-relaxed text-brand-dark"><span class="font-semibold text-brand">$1.50</span> for 100 credits afterwards</p>
        </div>

        <ul class="list-none mb-8 flex-grow">
          <li class="flex items-start gap-3 mb-3 text-sm leading-relaxed text-brand-dark"><span class="text-brand font-bold text-base shrink-0">✓</span><strong>Everything in Pro</strong></li>
          <li class="flex items-start gap-3 mb-3 text-sm leading-relaxed text-brand-dark"><span class="text-brand font-bold text-base shrink-0">✓</span>Orizuru 3.0 harness</li>
          <li class="flex items-start gap-3 mb-3 text-sm leading-relaxed text-brand-dark"><span class="text-brand font-bold text-base shrink-0">✓</span>SSO & MFA login</li>
          <li class="flex items-start gap-3 mb-3 text-sm leading-relaxed text-brand-dark"><span class="text-brand font-bold text-base shrink-0">✓</span>Dedicated account manager</li>
          <li class="flex items-start gap-3 mb-3 text-sm leading-relaxed text-brand-dark"><span class="text-brand font-bold text-base shrink-0">✓</span>Custom integrations</li>
        </ul>

        <a href="https://verso.fly.dev/playground/" class="block w-full py-4 rounded-pill text-center no-underline text-sm font-semibold transition duration-300 cursor-pointer border-2 border-brand bg-transparent text-brand hover:bg-brand hover:text-white">Get Started</a>
      </div>

    </div>

    <!-- FAQ Section -->
    <div class="max-w-[1200px] mx-auto mt-20">
      <h2 class="font-display text-[34px] font-semibold text-center mb-12 text-brand">Frequently asked questions</h2>

      <div class="grid grid-cols-1 nav:grid-cols-2 gap-6 items-start">
        <details class="group bg-white border-2 border-brand-border rounded-xl overflow-hidden transition duration-300 self-start hover:border-brand">
          <summary class="py-4 px-6 cursor-pointer font-semibold text-base text-brand list-none [&::-webkit-details-marker]:hidden flex justify-between items-center">
            What are credits?
            <span class="text-2xl font-light transition-transform duration-300 group-[.expanded]:rotate-45">+</span>
          </summary>
          <div class="faq-content grid grid-rows-[0fr] group-[.expanded]:grid-rows-[1fr] transition-[grid-template-rows] duration-200 ease-in-out">
            <div class="overflow-hidden opacity-0 group-[.expanded]:opacity-100 transition-opacity duration-150">
              <p class="px-6 pb-4 text-brand-muted leading-[1.8]">Credits are units of computation used by our AI. On average, generating a complete 10-slide presentation uses approximately 100-200 credits, depending on complexity and content length.</p>
            </div>
          </div>
        </details>

        <details class="group bg-white border-2 border-brand-border rounded-xl overflow-hidden transition duration-300 self-start hover:border-brand">
          <summary class="py-4 px-6 cursor-pointer font-semibold text-base text-brand list-none [&::-webkit-details-marker]:hidden flex justify-between items-center">
            What happens if I run out of credits?
            <span class="text-2xl font-light transition-transform duration-300 group-[.expanded]:rotate-45">+</span>
          </summary>
          <div class="faq-content grid grid-rows-[0fr] group-[.expanded]:grid-rows-[1fr] transition-[grid-template-rows] duration-200 ease-in-out">
            <div class="overflow-hidden opacity-0 group-[.expanded]:opacity-100 transition-opacity duration-150">
              <p class="px-6 pb-4 text-brand-muted leading-[1.8]">You can easily purchase additional credit packs or upgrade to a higher tier. We'll notify you when you're approaching your limit so you're never caught off guard.</p>
            </div>
          </div>
        </details>

        <details class="group bg-white border-2 border-brand-border rounded-xl overflow-hidden transition duration-300 self-start hover:border-brand">
          <summary class="py-4 px-6 cursor-pointer font-semibold text-base text-brand list-none [&::-webkit-details-marker]:hidden flex justify-between items-center">
            Can I change plans at any time?
            <span class="text-2xl font-light transition-transform duration-300 group-[.expanded]:rotate-45">+</span>
          </summary>
          <div class="faq-content grid grid-rows-[0fr] group-[.expanded]:grid-rows-[1fr] transition-[grid-template-rows] duration-200 ease-in-out">
            <div class="overflow-hidden opacity-0 group-[.expanded]:opacity-100 transition-opacity duration-150">
              <p class="px-6 pb-4 text-brand-muted leading-[1.8]">Yes! You can upgrade or downgrade your plan at any time. Changes take effect immediately, and we'll prorate any billing adjustments.</p>
            </div>
          </div>
        </details>

        <details class="group bg-white border-2 border-brand-border rounded-xl overflow-hidden transition duration-300 self-start hover:border-brand">
          <summary class="py-4 px-6 cursor-pointer font-semibold text-base text-brand list-none [&::-webkit-details-marker]:hidden flex justify-between items-center">
            Do credits roll over?
            <span class="text-2xl font-light transition-transform duration-300 group-[.expanded]:rotate-45">+</span>
          </summary>
          <div class="faq-content grid grid-rows-[0fr] group-[.expanded]:grid-rows-[1fr] transition-[grid-template-rows] duration-200 ease-in-out">
            <div class="overflow-hidden opacity-0 group-[.expanded]:opacity-100 transition-opacity duration-150">
              <p class="px-6 pb-4 text-brand-muted leading-[1.8]">Unused credits expire at the end of each monthly billing period. We recommend choosing a plan that matches your typical usage to maximize value.</p>
            </div>
          </div>
        </details>

        <details class="group bg-white border-2 border-brand-border rounded-xl overflow-hidden transition duration-300 self-start hover:border-brand">
          <summary class="py-4 px-6 cursor-pointer font-semibold text-base text-brand list-none [&::-webkit-details-marker]:hidden flex justify-between items-center">
            Is there a free trial?
            <span class="text-2xl font-light transition-transform duration-300 group-[.expanded]:rotate-45">+</span>
          </summary>
          <div class="faq-content grid grid-rows-[0fr] group-[.expanded]:grid-rows-[1fr] transition-[grid-template-rows] duration-200 ease-in-out">
            <div class="overflow-hidden opacity-0 group-[.expanded]:opacity-100 transition-opacity duration-150">
              <p class="px-6 pb-4 text-brand-muted leading-[1.8]">Yes! We offer a 14-day free trial with 500 credits to test all features. No credit card required to start.</p>
            </div>
          </div>
        </details>
      </div>
    </div>

  </section>

  <CtaBanner />
  <Footer />
</Layout>

<script>
  // Billing toggle with sliding indicator
  const annualBtn = document.getElementById('annualBtn');
  const monthlyBtn = document.getElementById('monthlyBtn');
  const indicator = document.getElementById('toggleIndicator');
  const annualPrices = document.querySelectorAll('.annual-price');
  const monthlyPrices = document.querySelectorAll('.monthly-price');

  function moveIndicator(btn: HTMLElement) {
    if (indicator) {
      indicator.style.left = btn.offsetLeft + 'px';
      indicator.style.width = btn.offsetWidth + 'px';
    }
  }

  if (annualBtn) moveIndicator(annualBtn);

  annualBtn?.addEventListener('click', () => {
    moveIndicator(annualBtn);
    annualBtn.classList.add('text-white');
    annualBtn.classList.remove('text-brand-muted');
    monthlyBtn?.classList.add('text-brand-muted');
    monthlyBtn?.classList.remove('text-white');
    annualPrices.forEach(price => { price.classList.remove('hidden'); price.classList.add('flex'); });
    monthlyPrices.forEach(price => { price.classList.add('hidden'); price.classList.remove('flex'); });
  });

  monthlyBtn?.addEventListener('click', () => {
    if (monthlyBtn) moveIndicator(monthlyBtn);
    monthlyBtn?.classList.add('text-white');
    monthlyBtn?.classList.remove('text-brand-muted');
    annualBtn?.classList.add('text-brand-muted');
    annualBtn?.classList.remove('text-white');
    annualPrices.forEach(price => { price.classList.add('hidden'); price.classList.remove('flex'); });
    monthlyPrices.forEach(price => { price.classList.remove('hidden'); price.classList.add('flex'); });
  });

  // FAQ smooth open/close
  const faqItems = document.querySelectorAll('details');

  function closeFaq(item: HTMLDetailsElement) {
    item.classList.remove('expanded');
    item.querySelector('.faq-content')?.addEventListener('transitionend', () => {
      item.open = false;
    }, { once: true });
  }

  faqItems.forEach(item => {
    item.querySelector('summary')?.addEventListener('click', (e) => {
      e.preventDefault();

      if (item.classList.contains('expanded')) {
        closeFaq(item as HTMLDetailsElement);
      } else {
        faqItems.forEach(other => {
          if (other !== item && other.classList.contains('expanded')) {
            closeFaq(other as HTMLDetailsElement);
          }
        });
        (item as HTMLDetailsElement).open = true;
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            item.classList.add('expanded');
          });
        });
      }
    });
  });
</script>
